OPENAI_API_KEY=replace_with_new_key
OPENAI_MODEL=gpt-4.1-mini
INVENTORY_DB_URL=postgresql+psycopg://user:pass@host:5432/dbname
AUTOMATION_API_TOKEN=replace_with_long_random_token
ALLOW_UI_AUTOMATION_WITHOUT_TOKEN=true
ASSISTANT_CONTEXT_CACHE_TTL_SECONDS=300

